# AI for Managers — Server Configuration
# Copy this file to .env and fill in the keys you want to use.
# These keys enable "Demo / Free Mode" so visitors do not need their own API keys.
# If both are set, OpenAI takes priority.

# OpenAI key — enables demo mode using gpt-4o-mini
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq key — completely free tier, no payment required
# Get yours at: https://console.groq.com (free signup)
GROQ_API_KEY=
